rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: content
    // Fields:
    //   - heroTitle: string
    //   - heroSub: string
    //   - portfolio: array of objects
    //   - services: array of objects
    //   - footerEmail: string
    //   - footerPhone: string
    //   - footerAddress: string
    //   - aboutText: string
    //   - aboutImage: string
    //   - upworkUrl: string
    //   - policies: array of objects
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "isaacmason928@gmail.com" || request.auth.uid == "Elt2lWpo62ckJhTFAf2XCucuhmW2");
    }

    function isValidContent(data) {
      return data.heroTitle is string &&
             data.heroSub is string &&
             data.portfolio is list &&
             data.services is list &&
             data.footerEmail is string &&
             data.footerPhone is string &&
             data.footerAddress is string &&
             data.aboutText is string &&
             data.aboutImage is string &&
             data.upworkUrl is string &&
             data.policies is list &&
             (!('caseStudies' in data) || data.caseStudies is list) &&
             (!('employmentHistory' in data) || data.employmentHistory is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/content {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidContent(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
